# Copy this file to `.env` in your Claude Code workspace root, then fill in your own keys.
# Your real .env is gitignored and must never be committed.
#
# Both keys are OPTIONAL. With no keys the skill still runs on the free research
# arm (WebFetch + WebSearch). The keys raise the hit-rate on harder sites.

# Firecrawl — used when a prospect site blocks a plain fetch or is JS-rendered.
# Get one at https://www.firecrawl.dev
FIRECRAWL_API_KEY=fc-your-key-here

# Apify — powers the premium signals arm (Google Maps owner-replies, LinkedIn posts)
# via the Apify MCP server. Token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your-token-here
